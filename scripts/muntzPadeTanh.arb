// scripts/muntzPadeTanh.arb
//
// Müntz–Padé approximant built entirely from the expression compiler.
// Stieltjes recurrence on the moment functional a(k)(v):
//   ⟨f, g⟩ ≔ Σᵢ Σⱼ fᵢ·gⱼ·a(i+j+1)(v)            (1-indexed moments)
//   h_n   = ⟨Q_n, Q_n⟩            -- factored out so it caches per integer n
//   s_n   = ⟨z·Q_n, Q_n⟩
//   α_n   = s_n / h_n
//   β_n   = h_n / h_{n-1}
//   Q_n   = (z − α_{n-1})·Q_{n-1} − β_{n-1}·Q_{n-2}   Q_0=1, Q_1=z−α_0
//   P_n   = (z − α_{n-1})·P_{n-1} − β_{n-1}·P_{n-2}   P_0=0, P_1=h_0
//
// Edit the PROBLEM PARAMETER block to drop in other scenarios. The tanh
// case (y' = 1 − y², y(0) = 0) is μ=1, pin=1, qin=0, rin=-1.
//
// Run with:   arb scripts/muntzPadeTanh.arb

int bits = 128;
int M    = 30;            // truncation order — bump if convergence is loose

// ── PROBLEM PARAMETERS ─────────────────────────────────────────────────────
Real μ = Real.named("μ").set("1", bits);
String pExpr = "pin:v→1";
String qExpr = "qin:v→0";
String rExpr = "rin:v→-1";
// ───────────────────────────────────────────────────────────────────────────

var context = new Context(μ).disableLommelPolynomials();

// Polynomial coefficients evaluated into context variables p, q, r.
var pin = ComplexPolynomialNullaryFunction.express(pExpr, context);
var qin = ComplexPolynomialNullaryFunction.express(qExpr, context);
var rin = ComplexPolynomialNullaryFunction.express(rExpr, context);
var p = ComplexPolynomial.named("p"); context.registerVariable(p); pin.evaluate(bits, p);
var q = ComplexPolynomial.named("q"); context.registerVariable(q); qin.evaluate(bits, q);
var r = ComplexPolynomial.named("r"); context.registerVariable(r); rin.evaluate(bits, r);

// Free variables: only v (moment-evaluation point). z is left UNregistered
// so it stays the polynomial indeterminate inside Q, P, Φden, Φnum bodies;
// Φ's curried inner parameter `z` binds it as a Complex at evaluation time.
var v = new Complex().setName("v"); context.registerVariable(v);

// Müntz coefficient sequence a(k)(v) — Riccati closed-form recurrence.
ComplexFunctionSequence.declare("a", context);
var a = ComplexPolynomialSequence.express(null,
    "a:k➔v➔when(k=1, p(v)/Γ(μ+1), else, (Γ((k-1)*μ+1)/Γ(k*μ+1))*(q(v)*a(k-1)(v)+r(v)*sum(j➔a(j)(v)*a(k-1-j)(v){j=1..k-2})))",
    context);

// ── Recurrence cluster: forward-declare, compile the non-leaves, express
//   the leaf last so its instantiation cascades through the others.
//   h, s, α, β are integer-domain ComplexSequences → framework caches them.
//   Q is integer-domain ComplexPolynomialSequence  → ditto.
context.declare("h", Integer.class, Complex.class, ComplexSequence.class);
context.declare("s", Integer.class, Complex.class, ComplexSequence.class);
context.declare("α", Integer.class, Complex.class, ComplexSequence.class);
context.declare("β", Integer.class, Complex.class, ComplexSequence.class);
ComplexPolynomialSequence.declare("Q", context);

Sequence.compile("h", Complex.class,
    "h:n➔sum(i➔sum(j➔Q(n)[i]*Q(n)[j]*a(i+j+1)(v){j=0..n}){i=0..n})",
    ComplexSequence.class, context);
Sequence.compile("s", Complex.class,
    "s:n➔sum(i➔sum(j➔Q(n)[i]*Q(n)[j]*a(i+j+2)(v){j=0..n}){i=0..n})",
    ComplexSequence.class, context);
Sequence.compile("α", Complex.class, "α:n➔s(n)/h(n)",   ComplexSequence.class, context);
Sequence.compile("β", Complex.class, "β:n➔h(n)/h(n-1)", ComplexSequence.class, context);

// Leaf of the cluster: expressing Q cascades instantiation through h, s, α, β.
var Q = ComplexPolynomialSequence.express("Q",
    "Q:n➔when(n=0, 1, n=1, z-α(0), else, (z-α(n-1))*Q(n-1)-β(n-1)*Q(n-2))",
    context);
var P = ComplexPolynomialSequence.express("P",
    "P:n➔when(n=0, 0, n=1, h(0), else, (z-α(n-1))*P(n-1)-β(n-1)*P(n-2))",
    context);

// ── Padé halves and approximant ──────────────────────────────────────────
var Φden = ComplexPolynomialSequence.express("Φden:M➔sum(j➔Q(M)[M-j]*z^j{j=1..M})+1", context);
var Φnum = ComplexPolynomialSequence.express("Φnum:M➔z*P(M)",                          context);
var Φ    = ComplexFunctionSequence  .express("Φ:M➔z➔Φnum(M)(z)/Φden(M)(z)",             context);

// ── Test against tanh oracle ─────────────────────────────────────────────
Integer Mfix = Integer.named("Mfix"); Mfix.set(M);
for (double tval : new double[]{0.0, 0.5, 1.0, 2.0}) {
  Complex tC = new Complex(); tC.set(String.valueOf(tval), bits);
  Complex zz = new Complex(); tC.pow(μ, bits, zz);
  Complex y = Φ.evaluate(Mfix, 1, bits, null).evaluate(zz, 1, bits, new Complex());
  out.printf("t=%4.1f  approx=%+.15f  tanh=%+.15f  Δ=%.2e%n",
             tval, y.getReal().doubleValue(), Math.tanh(tval),
             y.getReal().doubleValue() - Math.tanh(tval));
}
