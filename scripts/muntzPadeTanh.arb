// scripts/muntzPadeTanh.arb
//
// MГјntzвҖ“PadГ© approximant built entirely from the expression compiler.
// No procedural recurrence, no FunctionMapping lambdas, no forward
// declarations вҖ” every named expression is single-self-recursive (or
// non-recursive) so the compiler can produce each class in one shot.
//
// Recurrence is Stieltjes (inner products against the moment functional a):
//   вҹЁf, gвҹ© вү” ОЈбөў ОЈвұј fбөўВ·gвұјВ·a(i+j+1)(v)        (1-indexed moments)
//   ОұвӮҷвӮӢвӮҒ = вҹЁzВ·Q_{n-1}, Q_{n-1}вҹ© / вҹЁQ_{n-1}, Q_{n-1}вҹ©
//   ОІвӮҷвӮӢвӮҒ = вҹЁQ_{n-1}, Q_{n-1}вҹ© / вҹЁQ_{n-2}, Q_{n-2}вҹ©
//   Q_n  = (z вҲ’ ОұвӮҷвӮӢвӮҒ)В·Q_{n-1} вҲ’ ОІвӮҷвӮӢвӮҒВ·Q_{n-2},   Q_0=1, Q_1=z вҲ’ a(2)(v)/a(1)(v)
//   P_n  = (z вҲ’ ОұвӮҷвӮӢвӮҒ)В·P_{n-1} вҲ’ ОІвӮҷвӮӢвӮҒВ·P_{n-2},   P_0=0, P_1=a(1)(v)
//
// Edit the PROBLEM PARAMETER block to drop in other scenarios. The tanh
// case (y' = 1 вҲ’ yВІ, y(0) = 0) is Ој=1, pin=1, qin=0, rin=-1.
//
// Run with:   arb scripts/muntzPadeTanh.arb

int bits = 128;
int M    = 30;            // truncation order вҖ” bump if convergence is loose

// в”Җв”Җ PROBLEM PARAMETERS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
Real Ој = Real.named("Ој").set("1", bits);
String pExpr = "pin:vвҶ’1";
String qExpr = "qin:vвҶ’0";
String rExpr = "rin:vвҶ’-1";
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

var context = new Context(Ој).disableLommelPolynomials();

var pin = ComplexPolynomialNullaryFunction.express(pExpr, context);
var qin = ComplexPolynomialNullaryFunction.express(qExpr, context);
var rin = ComplexPolynomialNullaryFunction.express(rExpr, context);
var p = ComplexPolynomial.named("p"); context.registerVariable(p); pin.evaluate(bits, p);
var q = ComplexPolynomial.named("q"); context.registerVariable(q); qin.evaluate(bits, q);
var r = ComplexPolynomial.named("r"); context.registerVariable(r); rin.evaluate(bits, r);

var v = new Complex().setName("v"); context.registerVariable(v);
var z = new Complex().setName("z"); context.registerVariable(z);

// MГјntz coefficient sequence  a(k)(v)  вҖ” Riccati closed-form recurrence
ComplexFunctionSequence.declare("a", context);
var a = ComplexPolynomialSequence.express(null,
  "a:kвһ”vвһ”when(k=1,p(v)/О“(Ој+1),else,(О“((k-1)*Ој+1)/О“(k*Ој+1))*(q(v)*a(k-1)(v)+r(v)*sum(jвһ”a(j)(v)*a(k-1-j)(v){j=1..k-2})))",
  context);

// Monic orthogonal denominator polynomial  Q_n  (Stieltjes, inlined)
var Q = ComplexPolynomialSequence.express(
  "Q:nвһ”when(n=0,1,n=1,z-a(2)(v)/a(1)(v),else,(z-sum(iвһ”sum(jвһ”Q(n-1)[i]*Q(n-1)[j]*a(i+j+2)(v){j=0..n-1}){i=0..n-1})/sum(iвһ”sum(jвһ”Q(n-1)[i]*Q(n-1)[j]*a(i+j+1)(v){j=0..n-1}){i=0..n-1}))*Q(n-1)-(sum(iвһ”sum(jвһ”Q(n-1)[i]*Q(n-1)[j]*a(i+j+1)(v){j=0..n-1}){i=0..n-1})/sum(iвһ”sum(jвһ”Q(n-2)[i]*Q(n-2)[j]*a(i+j+1)(v){j=0..n-2}){i=0..n-2}))*Q(n-2))",
  context);

// Numerator polynomial  P_n  вҖ” same Оұ, ОІ coefficients
var P = ComplexPolynomialSequence.express(
  "P:nвһ”when(n=0,0,n=1,a(1)(v),else,(z-sum(iвһ”sum(jвһ”Q(n-1)[i]*Q(n-1)[j]*a(i+j+2)(v){j=0..n-1}){i=0..n-1})/sum(iвһ”sum(jвһ”Q(n-1)[i]*Q(n-1)[j]*a(i+j+1)(v){j=0..n-1}){i=0..n-1}))*P(n-1)-(sum(iвһ”sum(jвһ”Q(n-1)[i]*Q(n-1)[j]*a(i+j+1)(v){j=0..n-1}){i=0..n-1})/sum(iвһ”sum(jвһ”Q(n-2)[i]*Q(n-2)[j]*a(i+j+1)(v){j=0..n-2}){i=0..n-2}))*P(n-2))",
  context);

// PadГ© halves and approximant
var ОҰden = ComplexPolynomialSequence.express("ОҰden:Mвһ”sum(jвһ”Q(M)[M-j]*z^j{j=1..M})+1", context);
var ОҰnum = ComplexPolynomialSequence.express("ОҰnum:Mвһ”z*P(M)",                          context);
var ОҰ    = ComplexFunctionSequence  .express("ОҰ:Mвһ”zвһ”ОҰnum(M)(z)/ОҰden(M)(z)",             context);

// в”Җв”Җ Evaluation at fixed M against the tanh oracle в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
Integer Mfix = Integer.named("Mfix"); Mfix.set(M);
for (double tval : new double[]{0.0, 0.5, 1.0, 2.0}) {
  Complex tC = new Complex(); tC.set(String.valueOf(tval), bits);
  Complex zz = new Complex(); tC.pow(Ој, bits, zz);
  z.set(zz);
  Complex y = ОҰ.evaluate(Mfix, 1, bits, null).evaluate(zz, 1, bits, new Complex());
  out.printf("t=%4.1f  approx=%+.15f  tanh=%+.15f  О”=%.2e%n",
             tval, y.getReal().doubleValue(), Math.tanh(tval),
             y.getReal().doubleValue() - Math.tanh(tval));
}
