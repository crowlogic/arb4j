<configuration>
	<statusListener class="ch.qos.logback.core.status.NopStatusListener" />

	<appender name="console" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>[%thread] %logger{36} - %msg%n</pattern>
		</encoder>
	</appender>

	<!--
	  The Maven build overrides <resources> to copy only libarblib.so, so
	  src/main/resources/logback.xml never lands on the test classpath. Without
	  a config logback falls back to its built-in BasicConfigurator (root=DEBUG),
	  which floods every test run with FunctionNode/Expression debug spam even
	  though nobody enabled debug/trace. This test-scoped config restores a sane
	  INFO default for the whole suite.
	-->
	<logger name="arb.stochastic.Distribution" level="DEBUG" />

	<root level="INFO">
		<appender-ref ref="console" />
	</root>
</configuration>
