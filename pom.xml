<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<groupId>org.arblib</groupId>
	<artifactId>arb4j</artifactId>
	<version>0.99.9.9.9</version>
	<packaging>jar</packaging>
	<description>arb4j</description>

	<properties>
		<maven.compiler.source>26</maven.compiler.source>
		<maven.compiler.target>26</maven.compiler.target>
		<maven.compiler.release>26</maven.compiler.release>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<javafx.version>26.0.1</javafx.version>
		<asm.version>9.9.1</asm.version>
		<mdep.outputFile>class.path</mdep.outputFile>
		<argLine></argLine>
	</properties>

	<repositories>
		<repository>
			<id>central</id>
			<url>https://repo1.maven.org/maven2</url>
		</repository>
		<repository>
			<id>sonatype-releases</id>
			<url>https://oss.sonatype.org/content/repositories/releases</url>
		</repository>
		<repository>
			<id>oracle</id>
			<url>https://download.oracle.com/maven</url>
		</repository>
	</repositories>

	<dependencies>
		<dependency>
			<groupId>org.vineflower</groupId>
			<artifactId>vineflower</artifactId>
			<version>1.11.2</version>
		</dependency>
		<dependency>
			<groupId>guru.nidi</groupId>
			<artifactId>graphviz-java</artifactId>
			<version>0.18.1</version>
		</dependency>

		<dependency>
			<groupId>org.yaml</groupId>
			<artifactId>snakeyaml</artifactId>
			<version>2.4</version>
		</dependency>
		<dependency>
			<groupId>org.ow2.asm</groupId>
			<artifactId>asm</artifactId>
			<version>${asm.version}</version>
		</dependency>
		<dependency>
			<groupId>org.ow2.asm</groupId>
			<artifactId>asm-commons</artifactId>
			<version>${asm.version}</version>
		</dependency>
		<dependency>
			<groupId>org.ow2.asm</groupId>
			<artifactId>asm-util</artifactId>
			<version>${asm.version}</version>
		</dependency>
		<dependency>
			<groupId>org.openjfx</groupId>
			<artifactId>javafx-base</artifactId>
			<version>${javafx.version}</version>
			<classifier>linux</classifier>
		</dependency>
		<dependency>
			<groupId>org.openjfx</groupId>
			<artifactId>javafx-swing</artifactId>
			<version>${javafx.version}</version>
			<classifier>linux</classifier>
		</dependency>
		<dependency>
			<groupId>org.openjfx</groupId>
			<artifactId>javafx-graphics</artifactId>
			<version>${javafx.version}</version>
			<classifier>linux</classifier>
		</dependency>
		<dependency>
			<groupId>org.openjfx</groupId>
			<artifactId>javafx-controls</artifactId>
			<version>${javafx.version}</version>
			<classifier>linux</classifier>
			<exclusions>
				<exclusion>
					<groupId>org.openjfx</groupId>
					<artifactId>javafx-controls</artifactId>
				</exclusion>
			</exclusions>
		</dependency>
		<dependency>
			<groupId>org.scilab.forge</groupId>
			<artifactId>jlatexmath</artifactId>
			<version>1.0.7</version>
		</dependency>
		<dependency>
			<groupId>io.fair-acc</groupId>
			<artifactId>chartfx</artifactId>
			<version>11.3.1</version>
			<exclusions>
				<exclusion>
					<groupId>org.openjfx</groupId>
					<artifactId>javafx-controls</artifactId>
				</exclusion>
				<exclusion>
					<groupId>org.openjfx</groupId>
					<artifactId>javafx-base</artifactId>
				</exclusion>
				<exclusion>
					<groupId>org.openjfx</groupId>
					<artifactId>javafx-graphics</artifactId>
				</exclusion>
			</exclusions>
		</dependency>

		<dependency>
			<groupId>junit</groupId>
			<artifactId>junit</artifactId>
			<version>4.13.2</version>
		</dependency>
		<dependency>
			<groupId>guru.nidi.com.kitfox</groupId>
			<artifactId>svgSalamander</artifactId>
			<version>1.1.3</version>
		</dependency>
		<dependency>
			<groupId>org.slf4j</groupId>
			<artifactId>slf4j-api</artifactId>
			<version>2.0.9</version>
		</dependency>

		<dependency>
			<groupId>ch.qos.logback</groupId>
			<artifactId>logback-classic</artifactId>
			<version>1.4.14</version>
		</dependency>

	</dependencies>

	<build>
		<directory>build</directory>
		<outputDirectory>build/classes</outputDirectory>
		<testOutputDirectory>build/test-classes</testOutputDirectory>


		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.14.0</version>
				<configuration>
					<release>26</release>
				</configuration>
			</plugin>

			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<version>3.2.5</version>
				<configuration>
					<argLine>-ea --illegal-native-access=allow
						--sun-misc-unsafe-memory-access=allow
						-Djava.library.path=${project.basedir} ${argLine}</argLine>
				</configuration>
			</plugin>

			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-javadoc-plugin</artifactId>
				<version>3.6.3</version>
				<configuration>
					<source>26</source>
					<additionalJOptions>
						<additionalJOption>-Xdoclint:none</additionalJOption>
						<additionalJOption>-quiet</additionalJOption>
					</additionalJOptions>
					<!--
					  maven-javadoc-plugin's default package enumeration walks
					  the source tree and emits a flat @packages file to the
					  javadoc tool. javadoc 26 then aborts with

					      error: No source files for package <name>

					  whenever any listed package contains only
					  package-info.java (the package directory has no
					  ordinary .java sources).

					  Switching from <packages> to <subpackages> tells javadoc
					  to discover sources recursively under <sourcepath>
					  rather than processing an explicit list. Under that
					  mode a directory whose only file is package-info.java
					  is silently skipped instead of failing the run.
					-->
					<sourcepath>${project.basedir}/src/main/java</sourcepath>
					<subpackages>arb</subpackages>
				</configuration>
				<executions>
					<execution>
						<id>attach-javadocs</id>
						<goals>
							<goal>jar</goal>
						</goals>
					</execution>
				</executions>
			</plugin>

			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-source-plugin</artifactId>
				<version>3.3.0</version>
				<executions>
					<execution>
						<id>attach-sources</id>
						<goals>
							<goal>jar</goal>
						</goals>
					</execution>
				</executions>
			</plugin>

			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-resources-plugin</artifactId>
				<version>3.3.1</version>
				<configuration>
					<outputDirectory>build/classes</outputDirectory>
				</configuration>
			</plugin>

			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-shade-plugin</artifactId>
				<version>3.6.2</version>
				<dependencies>
					<dependency>
						<groupId>org.ow2.asm</groupId>
						<artifactId>asm</artifactId>
						<version>${asm.version}</version>
					</dependency>
					<dependency>
						<groupId>org.ow2.asm</groupId>
						<artifactId>asm-commons</artifactId>
						<version>${asm.version}</version>
					</dependency>
				</dependencies>
				<executions>
					<execution>
						<id>fat-jar</id>
						<phase>none</phase>
						<goals>
							<goal>shade</goal>
						</goals>
						<configuration>
							<!-- Replace the thin jar with the fat jar -->
							<shadedArtifactAttached>false</shadedArtifactAttached>
							<createDependencyReducedPom>false</createDependencyReducedPom>
							<minimizeJar>false</minimizeJar>
							<!--
							  Pull every transitive dep into the jar, including JavaFX
							  (linux-classifier native libs at META-INF/native/...).
							  Strip module-info.class so the resulting jar loads as an
							  automatic module without colliding declarations from
							  shaded modules.
							-->
							<artifactSet>
								<includes>
									<include>*:*</include>
								</includes>
							</artifactSet>
							<filters>
								<filter>
									<artifact>*:*</artifact>
									<excludes>
										<exclude>module-info.class</exclude>
										<exclude>META-INF/versions/**/module-info.class</exclude>
										<exclude>META-INF/MANIFEST.MF</exclude>
										<exclude>META-INF/*.SF</exclude>
										<exclude>META-INF/*.DSA</exclude>
										<exclude>META-INF/*.RSA</exclude>
										<exclude>META-INF/maven/**</exclude>
									</excludes>
								</filter>
							</filters>
							<transformers>
								<transformer
									implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
								<transformer
									implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
									<mainClass>arb.expressions.Expression</mainClass>
									<manifestEntries>
										<Multi-Release>true</Multi-Release>
									</manifestEntries>
								</transformer>
							</transformers>
							<!--
							  Relocate every non-JavaFX third-party prefix into
							  org.arblib.shaded.* so a downstream classpath can pull a
							  conflicting version without colliding. arb.* is the project's
							  own code and stays put. JavaFX artifacts are excluded from
							  the artifact set above and supplied by the runtime JDK on
							  the module path.
							-->
							<relocations>
								<relocation><pattern>org.objectweb.asm</pattern><shadedPattern>org.arblib.shaded.asm</shadedPattern></relocation>
								<relocation><pattern>org.slf4j</pattern><shadedPattern>org.arblib.shaded.slf4j</shadedPattern></relocation>
								<relocation><pattern>ch.qos.logback</pattern><shadedPattern>org.arblib.shaded.logback</shadedPattern></relocation>
								<relocation><pattern>org.yaml.snakeyaml</pattern><shadedPattern>org.arblib.shaded.snakeyaml</shadedPattern></relocation>
								<relocation><pattern>io.fair_acc</pattern><shadedPattern>org.arblib.shaded.fair_acc</shadedPattern></relocation>
								<relocation><pattern>org.scilab.forge.jlatexmath</pattern><shadedPattern>org.arblib.shaded.jlatexmath</shadedPattern></relocation>
								<relocation><pattern>org.jetbrains.java.decompiler</pattern><shadedPattern>org.arblib.shaded.vineflower</shadedPattern></relocation>
								<relocation><pattern>guru.nidi.graphviz</pattern><shadedPattern>org.arblib.shaded.graphvizjava</shadedPattern></relocation>
								<relocation><pattern>com.eclipsesource.v8</pattern><shadedPattern>org.arblib.shaded.j2v8</shadedPattern></relocation>
								<relocation><pattern>com.kitfox.svg</pattern><shadedPattern>org.arblib.shaded.svgsalamander</shadedPattern></relocation>
								<relocation><pattern>org.kordamp.ikonli</pattern><shadedPattern>org.arblib.shaded.ikonli</shadedPattern></relocation>
								<relocation><pattern>org.controlsfx</pattern><shadedPattern>org.arblib.shaded.controlsfx</shadedPattern></relocation>
								<relocation><pattern>impl.org.controlsfx</pattern><shadedPattern>org.arblib.shaded.controlsfx_impl</shadedPattern></relocation>
								<relocation><pattern>org.apache.commons</pattern><shadedPattern>org.arblib.shaded.commons</shadedPattern></relocation>
								<relocation><pattern>org.HdrHistogram</pattern><shadedPattern>org.arblib.shaded.hdrhistogram</shadedPattern></relocation>
								<relocation><pattern>org.jtransforms</pattern><shadedPattern>org.arblib.shaded.jtransforms</shadedPattern></relocation>
								<relocation><pattern>pl.edu.icm.jlargearrays</pattern><shadedPattern>org.arblib.shaded.jlargearrays</shadedPattern></relocation>
								<relocation><pattern>com.intellij.lang.annotations</pattern><shadedPattern>org.arblib.shaded.intellij.annotations</shadedPattern></relocation>
								<relocation><pattern>org.intellij.lang.annotations</pattern><shadedPattern>org.arblib.shaded.intellij.lang.annotations</shadedPattern></relocation>
								<relocation><pattern>org.jetbrains.annotations</pattern><shadedPattern>org.arblib.shaded.jetbrains.annotations</shadedPattern></relocation>
								<relocation><pattern>net.arnx.nashorn.lib</pattern><shadedPattern>org.arblib.shaded.nashornpromise</shadedPattern></relocation>
								<relocation><pattern>ar.com.hjg.pngj</pattern><shadedPattern>org.arblib.shaded.pngj</shadedPattern></relocation>
								<relocation><pattern>org.junit</pattern><shadedPattern>org.arblib.shaded.junit</shadedPattern></relocation>
								<relocation><pattern>junit</pattern><shadedPattern>org.arblib.shaded.junit_legacy</shadedPattern></relocation>
								<relocation><pattern>org.hamcrest</pattern><shadedPattern>org.arblib.shaded.hamcrest</shadedPattern></relocation>
								<relocation><pattern>javax.annotation</pattern><shadedPattern>org.arblib.shaded.jsr305</shadedPattern></relocation>
							</relocations>
						</configuration>
					</execution>
				</executions>
			</plugin>

			<!--
			  Post-shade fixup: maven-shade-plugin relocates bytecode references
			  but does not rewrite class names embedded in XML/properties
			  resources (MSHADE-156). The shipped logback*.xml literally
			  references ch.qos.logback.core.* which after shading no longer
			  resolves. Rewrite those literals inside the produced fat jar so
			  logback's Class.forName() lookups at config time hit the shaded
			  org.arblib.shaded.logback.* classes.
			-->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-antrun-plugin</artifactId>
				<version>3.1.0</version>
				<executions>
					<execution>
						<id>rewrite-logback-xml-in-fat-jar</id>
						<phase>none</phase>
						<goals><goal>run</goal></goals>
						<configuration>
							<target>
								<property name="fatjar" value="${project.build.directory}/${project.build.finalName}.jar"/>
								<property name="work" value="${project.build.directory}/logback-rewrite"/>
								<delete dir="${work}" quiet="true"/>
								<mkdir dir="${work}"/>
								<unzip src="${fatjar}" dest="${work}">
									<patternset><include name="logback*.xml"/></patternset>
								</unzip>
								<replaceregexp match="ch\.qos\.logback" replace="org.arblib.shaded.logback" flags="g" byline="false">
									<fileset dir="${work}" includes="logback*.xml"/>
								</replaceregexp>
								<jar destfile="${fatjar}" update="true" basedir="${work}" includes="logback*.xml"/>
								<delete dir="${work}" quiet="true"/>
							</target>
						</configuration>
					</execution>
				</executions>
			</plugin>

			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-dependency-plugin</artifactId>
				<version>3.6.1</version>
				<executions>
					<!--
						Development classpath: paths point into the local ~/.m2
						repository so a checkout's bin/* wrappers can resolve
						dependencies straight out of Maven's cache. Bound to
						generate-sources so it is in place before any compile.
					-->
					<execution>
						<id>build-classpath</id>
						<phase>generate-sources</phase>
						<goals>
							<goal>build-classpath</goal>
						</goals>
						<configuration>
							<outputFile>${project.basedir}/class.path</outputFile>
							<includeScope>runtime</includeScope>
						</configuration>
					</execution>
				</executions>
			</plugin>

		</plugins>
	</build>

	<profiles>
		<!--
		  Debian packaging profile.  Default `mvn install` produces only
		  the thin jar that downstream Maven consumers (bonanzai, etc.)
		  resolve against; it does NOT copy every runtime jar into
		  target/dependency and does NOT emit class.path.debian.  Those
		  staging steps run only when this profile is active, which
		  debian/rules turns on via `mvn -Pdebian package`.
		-->
		<profile>
			<id>debian</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-dependency-plugin</artifactId>
						<executions>
							<!--
								Debian classpath: rewrites every entry to
								/usr/share/arb4j/lib/<basename>.jar.
								debian/rules ships this file as
								/usr/share/arb4j/class.path and env.sh
								exports ARB4J_CLASSPATH=$ARB4J_JAR:<file>.
							-->
							<execution>
								<id>build-classpath-debian</id>
								<phase>prepare-package</phase>
								<goals>
									<goal>build-classpath</goal>
								</goals>
								<configuration>
									<outputFile>${project.build.directory}/class.path.debian</outputFile>
									<includeScope>runtime</includeScope>
									<prefix>/usr/share/arb4j/lib</prefix>
									<stripVersion>false</stripVersion>
								</configuration>
							</execution>
							<!--
								Stage every runtime dependency jar into
								target/dependency so debian/rules can copy
								them into /usr/share/arb4j/lib and unzip the
								JavaFX linux-classifier and j2v8 jars to
								extract their .so entries into /usr/lib/jni.
							-->
							<execution>
								<id>copy-dependencies-debian</id>
								<phase>prepare-package</phase>
								<goals>
									<goal>copy-dependencies</goal>
								</goals>
								<configuration>
									<outputDirectory>${project.build.directory}/dependency</outputDirectory>
									<includeScope>runtime</includeScope>
									<stripVersion>false</stripVersion>
									<overWriteReleases>true</overWriteReleases>
									<overWriteSnapshots>true</overWriteSnapshots>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>

		<!--
		  Tracing profile: enable expression-compiler debug logging plus the
		  static `arb4j.trace` and `arb4j.traceNodes` flags so a single
		  invocation of `mvn -Ptrace test -Dtest=Foo#bar` reproduces the
		  exact diagnostic stream used while debugging splice/curry issues
		  (see issue #994).
		-->
		<profile>
			<id>trace</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-surefire-plugin</artifactId>
						<configuration>
							<argLine>-ea --illegal-native-access=allow
								--sun-misc-unsafe-memory-access=allow
								-Djava.library.path=${project.basedir}
								-Darb4j.trace=true
								-Darb4j.traceNodes=true
								-Dlogback.configurationFile=logback-debug.xml</argLine>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>
