Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"g", ",", "\[Lambda]"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"n", "=", "200"}], ";", 
   RowBox[{"(*", 
    RowBox[{"Number", " ", "of", " ", "Gauss", " ", "points"}], "*)"}], 
   RowBox[{"\[Lambda]", "=", "1"}], ";"}], 
  RowBox[{"(*", "eigenvalue", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"pts", ",", "w"}], "}"}], "=", 
    RowBox[{"Most", "[", 
     RowBox[{"NIntegrate`GaussRuleData", "[", 
      RowBox[{"n", ",", "MachinePrecision"}], "]"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Map", " ", "interval", " ", 
    RowBox[{"from", "[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}], " ", "to", " ", "general", " ", 
    "interval"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sList", "=", 
   RowBox[{"Rescale", "[", 
    RowBox[{"pts", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"wList", "=", 
    RowBox[{"w", "*", "2"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "regularized", " ", "integral"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"integral", "[", 
     RowBox[{"s_", ",", "gVals_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Total", "[", 
      RowBox[{"wList", " ", 
       RowBox[{"(", 
        RowBox[{"s", "+", "1"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"s", "-", "1"}], ")"}], " ", "gVals"}], "]"}], "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"\[Pi]", "/", "2"}], "]"}]}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Matrix", " ", "equation", " ", 
     RowBox[{"(", 
      RowBox[{"I", "-", "\[Lambda]K"}], ")"}], "g"}], "=", "g"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"matrix", "=", 
    RowBox[{
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"Table", "[", 
       RowBox[{"1", ",", 
        RowBox[{"{", "n", "}"}]}], "]"}], "]"}], "-", 
     RowBox[{"\[Lambda]", " ", 
      RowBox[{"Outer", "[", 
       RowBox[{"integral", ",", "sList", ",", "sList"}], "]"}], " ", 
      RowBox[{"DiagonalMatrix", "[", "wList", "]"}]}]}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Solve", " ", "matrix", " ", "equation"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gValues", "=", 
    RowBox[{"LinearSolve", "[", 
     RowBox[{"matrix", ",", 
      RowBox[{"Table", "[", 
       RowBox[{"1", ",", 
        RowBox[{"{", "n", "}"}]}], "]"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Interpolate", " ", "to", " ", "get", " ", "a", " ", "continuous", " ", 
     "function"}], ",", 
    RowBox[{"and", " ", "undo", " ", "the", " ", "regularization"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gInterpolated", "=", 
    RowBox[{"Interpolation", "[", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"sList", ",", "gValues"}], "}"}], "]"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Plot", " ", "the", " ", "solution"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"gInterpolated", "[", "s", "]"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"s", "+", "1"}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{"s", "-", "1"}], ")"}]}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"s", ",", 
     RowBox[{"-", "0.9"}], ",", "0.9"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<s\>\"", ",", "\"\<g(s)\>\""}], "}"}]}]}], 
  "]"}], "\n"}], "Input",
 CellChangeTimes->{{3.9027786684902287`*^9, 3.902778689449524*^9}, {
  3.902778727515504*^9, 3.90277872773097*^9}, {3.902779159733837*^9, 
  3.902779162371924*^9}},
