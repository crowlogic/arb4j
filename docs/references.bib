@article{Hansell1980,
	title        = {Some Consequences of $(V = L)$ in the Theory of Analytic Sets},
	author       = {R. W. Hansell},
	year         = 1980,
	month        = {oct},
	journal      = {Proceedings of the American Mathematical Society},
	publisher    = {American Mathematical Society},
	volume       = 80,
	number       = 2,
