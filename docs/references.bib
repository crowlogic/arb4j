	url          = {http://links.jstor.org/sici?sici=0002-9939\%28198010\%2980\%3A2\%3C311\%3ASCOITT\%3E2.0.CO\%3B2-B},
	copyright    = {Copyright 1980 American Mathematical Society},
	abstract     = {Following G. M. Reed's definition of a $Q$-set, we define a \$Q\_A\$-set to be any non-\$\sigma\$-discrete topological space with the property that each subset is (relatively) analytic (= Souslin-\$\mathscr{F}\$ set). Clearly every \$Q\$-set is a \$Q\_A\$-set. The discrete irrational extension of the space of real numbers is an example of a first countable hereditarily paracompact (Hausdorff) \$Q\_A\$-set which is not a \$Q\$-set. THEOREM. \$(V = L)\$ Let \$X\$ be a first countable normal space all of whose subsets are analytic. Then \$X\$ is \$\sigma\$-discrete if and only if the product of \$X\$ with the space of irrational numbers is normal. A new structural property of analytic sets is developed in order to utilize a proof technique due to Reed. Several corollaries are obtained on properties of completely additive-analytic families of sets in general metric spaces.},
	jstor_articletype = {Full Length Article},
	jstor_date   = 198010,
	jstor_formatteddate = {Oct., 1980},
	keywords     = {54H05, 02K05, 04A15, 54E35, 54A25, $(V = L)$, analytic set, \$\sigma\$-discrete, \$Q\$-set, \$Q\_A\$-set, completely additive-analytic family, \$\sigma\$-discretely decomposable, \$d\$-family, metrizable space}
}
