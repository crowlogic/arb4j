Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Calculate", " ", "the", " ", "variogram"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"variogram", "[", 
     RowBox[{"tau_", ",", "data_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Ntau", ",", "sum"}], "}"}], ",", 
      RowBox[{
       RowBox[{"Ntau", "=", 
        RowBox[{
         RowBox[{"Length", "[", "data", "]"}], "-", "tau"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sum", "=", 
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"data", "[", 
             RowBox[{"[", 
              RowBox[{"Range", "[", 
               RowBox[{"1", ",", "Ntau"}], "]"}], "]"}], "]"}], "-", 
            RowBox[{"data", "[", 
             RowBox[{"[", 
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{"1", "+", "tau"}], ",", 
                RowBox[{"Ntau", "+", "tau"}]}], "]"}], "]"}], "]"}]}], ")"}], 
          "^", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sum", "/", 
        RowBox[{"(", "Ntau", ")"}]}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Calculate", " ", "and", " ", "store", " ", "variogram", " ", "values", 
     " ", "from", " ", "0", " ", "to", " ", "10"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"variogramValues", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"variogram", "[", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{"tau", "/", "dt"}], "]"}], ",", "yValues"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"tau", ",", "0", ",", "10", ",", "0.1"}], "}"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Plot", " ", "the", " ", "variogram"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"variogramValues", ",", 
     RowBox[{"DataRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "10"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<Tau\>\"", ",", "\"\<Variogram\>\""}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.902288910315308*^9, 3.9022889364525347`*^9}, {
  3.902289131753089*^9, 3.902289131984488*^9}, {3.902290063382016*^9, 
  3.902290075992117*^9}},ExpressionUUID->"09a60af5-09a8-42f6-8e60-\
887a49e0502c"],

Cell[BoxData[
 GraphicsBox[{{}, {{}, {}, 
