Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Define", " ", "your", " ", "function"}], ";", 
     RowBox[{"for", " ", "example"}]}], ",", 
    RowBox[{
     RowBox[{"f", 
      RowBox[{"(", "x", ")"}]}], "=", 
     RowBox[{"sin", 
      RowBox[{"(", "x", ")"}]}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x_", "]"}], ":=", 
    RowBox[{"Sin", "[", "x", "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Generate", " ", "the", " ", "sample", " ", "of", " ", "the", " ", 
     "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dt", "=", "0.1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xValues", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "50", ",", "dt"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yValues", "=", 
     RowBox[{"f", "/@", "xValues"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Plot", " ", "the", " ", "entire", " ", "discretized", " ", "function"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"xValues", ",", "yValues"}], "}"}], "]"}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", "\"\<f(x)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], "\n"}]}]], "Input",
