Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "normalized", " ", "Fourier", " ", "transforms",
     " ", "of", " ", "the", " ", "Chebyshev", " ", "polynomials"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Y", "[", 
     RowBox[{"n_", ",", "y_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "f", "}"}], ",", 
      RowBox[{
       RowBox[{"f", "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", "n"}], "]"}], " ", 
         RowBox[{"ChebyshevT", "[", 
          RowBox[{"n", ",", "x"}], "]"}], " ", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "I"}], " ", "x", " ", "y"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Integrate", "[", 
         RowBox[{"f", ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"4", " ", "Pi", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", 
               RowBox[{"n", "^", "2"}]}], "-", "1"}], ")"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"4", " ", 
             RowBox[{"n", "^", "2"}]}], "-", "1"}], ")"}]}], "]"}]}]}]}], 
     "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "the", " ", "inner", " ", "product"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"InnerProd", "[", 
     RowBox[{"n_", ",", "m_"}], "]"}], ":=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Y", "[", 
        RowBox[{"n", ",", "y"}], "]"}], " ", 
       RowBox[{"Conjugate", "[", 
        RowBox[{"Y", "[", 
         RowBox[{"m", ",", "y"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Define", " ", "Gram"}], "-", 
     RowBox[{"Schmidt", " ", "process"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"GramSchmidt", "[", "vecList_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "n", ",", "m", ",", "inner", ",", "projection", ",", "u", ",", "v", 
        ",", 
        RowBox[{"orthoList", "=", 
         RowBox[{"{", "}"}]}]}], "}"}], ",", 
      RowBox[{
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"n", "=", "1"}], ",", 
         RowBox[{"n", "\[LessEqual]", 
          RowBox[{"Length", "[", "vecList", "]"}]}], ",", 
         RowBox[{"n", "++"}], ",", 
         RowBox[{
          RowBox[{"v", "=", 
           RowBox[{"vecList", "[", 
            RowBox[{"[", "n", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"projection", "=", "0"}], ";", "\[IndentingNewLine]", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"m", "=", "1"}], ",", 
            RowBox[{"m", "<", "n"}], ",", 
            RowBox[{"m", "++"}], ",", 
            RowBox[{
             RowBox[{"u", "=", 
              RowBox[{"orthoList", "[", 
               RowBox[{"[", "m", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"inner", "=", 
              RowBox[{"Integrate", "[", 
               RowBox[{
                RowBox[{"u", " ", "v"}], ",", 
                RowBox[{"{", 
                 RowBox[{"y", ",", 
                  RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"projection", "=", 
              RowBox[{"projection", "+", 
               RowBox[{"inner", " ", "u"}]}]}], ";"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"u", "=", 
           RowBox[{"Simplify", "[", 
            RowBox[{"v", "-", "projection"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"u", "=", 
           RowBox[{"Simplify", "[", 
            RowBox[{"u", "/", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"Integrate", "[", 
               RowBox[{
                RowBox[{"u", " ", 
                 RowBox[{"Conjugate", "[", "u", "]"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"y", ",", 
                  RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], 
               "]"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"orthoList", ",", "u"}], "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "orthoList"}]}], "]"}]}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{"Generate", " ", "the", " ", "function", " ", "list"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"funcList", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Y", "[", 
        RowBox[{"n", ",", "y"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "20"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Apply", " ", "Gram"}], "-", 
     RowBox[{"Schmidt", " ", "process"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"orthoFuncs", "=", 
     RowBox[{"GramSchmidt", "[", "funcList", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Output", " ", "the", " ", "orthogonalized", " ", "functions"}], 
    "*)"}], "\[IndentingNewLine]", "orthoFuncs", "\n"}]}]], "Input",
