       RowBox[{"2", ",", "t"}], "]"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"u3Unnormalized", "=", 
   RowBox[{
    RowBox[{"FourierTn", "[", 
     RowBox[{"2", ",", "t"}], "]"}], "-", 
    RowBox[{"InnerProductWithU1", "*", "u1"}], "-", 
    RowBox[{"InnerProductWithU2", "*", "u2"}]}]}], ";"}], "\n", 
