Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "Fourier", " ", "transform", " ", "of", " ", "Chebyshev", 
    " ", "polynomials", " ", "using", " ", "Alpha", " ", "function"}], "*)"}],
   "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"FourierTn", "[", 
     RowBox[{"m_", ",", "lambda_"}], "]"}], ":=", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Alpha", "[", 
        RowBox[{"m", ",", "n"}], "]"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", "*", "lambda"}], "]"}], "/", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"I", "*", "lambda"}], ")"}], "^", "n"}]}], "+", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"n", "+", "m"}], ")"}]}], "*", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], "*", "lambda"}], "]"}], "/", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"I", "*", "lambda"}], ")"}], "^", "n"}]}]}]}], ")"}]}], 
      ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", 
        RowBox[{"m", "+", "1"}]}], "}"}]}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "inner", " ", "product", " ", "with", " ", 
     "respect", " ", "to", " ", "J0", 
     RowBox[{"(", "t", ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"InnerProduct", "[", 
     RowBox[{"f_", ",", "g_"}], "]"}], ":=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", "t", "]"}], "*", 
       RowBox[{"Conjugate", "[", 
        RowBox[{"g", "[", "t", "]"}], "]"}], "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"0", ",", "t"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\n", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"FourierTn", "[", 
       RowBox[{"0", ",", "t"}], "]"}], "Pi"], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.90331694197923*^9, 3.903316941979376*^9}, {
   3.903317354206667*^9, 3.9033173635607243`*^9}, 3.903317528546514*^9, {
