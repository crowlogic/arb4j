Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "symbolic", " ", "inner", " ", "product"}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"InnerProductSymbolic", "[", 
     RowBox[{"f_", ",", "g_"}], "]"}], ":=", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{"f", "*", "g", "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"0", ",", "t"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"WorkingPrecision", "\[Rule]", "20"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "v1", " ", "and", " ", "v2"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"v1", "=", 
     RowBox[{"FourierTn", "[", 
      RowBox[{"0", ",", "t"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"v2", "=", 
     RowBox[{"FourierTn", "[", 
      RowBox[{"1", ",", "t"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "u1", " ", "by", " ", "normalizing", " ", "v1"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"norm1", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"InnerProductSymbolic", "[", 
       RowBox[{"v1", ",", "v1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"u1", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"v1", "/", "norm1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "the", " ", "components", " ", "for", " ", "u2"}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"innerProd1", "=", 
     RowBox[{"InnerProductSymbolic", "[", 
      RowBox[{"u1", ",", "v2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"innerProd2", "=", 
     RowBox[{"InnerProductSymbolic", "[", 
      RowBox[{"u1", ",", "u1"}], "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
     "This", " ", "should", " ", "be", " ", "1", " ", "since", " ", "u1", " ",
       "is", " ", "normalized"}], "*)"}], 
    RowBox[{"(*", 
     RowBox[{"Compute", " ", "u2", " ", "and", " ", "normalize", " ", "it"}], 
     "*)"}], 
    RowBox[{"u2Unnormalized", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"v2", "-", 
       RowBox[{
        RowBox[{"innerProd1", "/", "innerProd2"}], "*", "u1"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"norm2", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"InnerProductSymbolic", "[", 
       RowBox[{"u2Unnormalized", ",", "u2Unnormalized"}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"u2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"u2Unnormalized", "/", "norm2"}], "]"}]}], ";"}], 
   "\n"}]}]], "Input",
 CellChangeTimes->{{3.903321088734515*^9, 3.903321088734708*^9}, 
   3.903321132269266*^9, {3.9033224089336653`*^9, 3.903322414532764*^9}},
 CellLabel->
  "In[350]:=",ExpressionUUID->"71173763-2b5f-4d16-88f6-9a75d87e17a5"],

