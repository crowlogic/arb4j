Cell[BoxData[{
 RowBox[{
  RowBox[{"InnerProductWithU1", "=", 
   RowBox[{"InnerProduct", "[", 
    RowBox[{"u1", ",", 
     RowBox[{"FourierTn", "[", 
      RowBox[{"2", ",", "t"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"InnerProductWithU2", "=", 
