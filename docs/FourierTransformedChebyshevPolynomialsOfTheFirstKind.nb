Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Calculate", " ", "Fourier", " ", "Transforms", " ", "without", " ", "2", 
    "\[Pi]", " ", "factor"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"fourierTransforms", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ChebyshevT", "[", 
           RowBox[{"n", ",", "x"}], "]"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", "f", " ", "x"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Plot", " ", "Fourier", " ", "Transforms"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot1", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{"ReIm", "[", "fourierTransforms", "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{"f", "\[Rule]", "freq"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"freq", ",", 
         RowBox[{"-", "20"}], ",", "20"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "20"}], ",", "20"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "2"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Automatic", ",", "Dashed"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "\[Rule]", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\"\<Re[FT[T\>\"", "<>", 
              RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<]]\>\""}], ",", 
             
             RowBox[{"\"\<Im[FT[T\>\"", "<>", 
              RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<]]\>\""}]}], 
            "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "0", ",", "4"}], "}"}]}], "]"}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Plot", " ", "Bessel", " ", "Function"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot2", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"BesselJ", "[", 
        RowBox[{"0", ",", "freq"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"freq", ",", 
         RowBox[{"-", "20"}], ",", "20"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "20"}], ",", "20"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "2"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Black"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "\[Rule]", 
        RowBox[{"{", "\"\<J_0(t)\>\"", "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Combine", " ", "Plots", " ", "and", " ", "Legends"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"plot1", ",", "plot2"}], "]"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.9030364575353613`*^9, 3.903036457535574*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"f01bd3e3-616b-43cd-9368-12079e21ff43"],

