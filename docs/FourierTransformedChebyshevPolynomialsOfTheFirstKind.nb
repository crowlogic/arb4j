Notebook[{
Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "alpha", " ", "function", " ", "based", " ", "on", " ", "m",
     " ", "and", " ", "n", " ", "using", " ", "Piecewise"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Alpha", "[", 
     RowBox[{"m_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", "m"}], ",", 
         RowBox[{"n", "\[Equal]", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"m", "+", "1"}], ")"}]}], "*", 
          RowBox[{"m", "^", "2"}]}], ",", 
         RowBox[{"n", "\[Equal]", "2"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"m", "+", "n", "-", "1"}], ")"}]}], "*", 
          RowBox[{"2", "^", 
           RowBox[{"(", 
            RowBox[{"n", "-", "2"}], ")"}]}], "*", "m", "*", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Binomial", "[", 
              RowBox[{
               RowBox[{"n", "+", "k", "-", "3"}], ",", 
               RowBox[{"k", "-", "1"}]}], "]"}], "*", 
             RowBox[{"Product", "[", 
              RowBox[{
               RowBox[{"m", "-", "j"}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "k", ",", 
                 RowBox[{"n", "+", "k", "-", "3"}]}], "}"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", 
              RowBox[{"m", "-", "n", "+", "2"}]}], "}"}]}], "]"}]}], ",", 
         RowBox[{"n", "\[GreaterEqual]", "3"}]}], "}"}]}], "}"}], "]"}]}], 
   "\n"}]}]], "Input",
 CellChangeTimes->{{3.90331694197923*^9, 3.903316941979376*^9}, {
   3.903317354206667*^9, 3.9033173635607243`*^9}, 3.903317528546514*^9, {
