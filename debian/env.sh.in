#!/bin/sh
# Sourced by every /usr/bin wrapper to point at the FHS-installed arb4j layout.
ARB4J_HOME=/usr/share/arb4j
ARB4J_JAR=/usr/share/java/arb4j.jar
ARB4J_NATIVE_DIR=/usr/lib/jni
ARB4J_LIB_DIR=$ARB4J_HOME/lib
# Thin jar plus a discrete jar per dependency under /usr/share/arb4j/lib.
# The class.path file lists those dependency jars one per line, with
# absolute /usr/share/arb4j/lib/<basename>.jar paths emitted at build time
# by maven-dependency-plugin's build-classpath-debian execution.
ARB4J_CLASSPATH=$ARB4J_JAR:$(tr '\n' ':' < $ARB4J_HOME/class.path | sed 's/:$//')
export ARB4J_HOME ARB4J_JAR ARB4J_NATIVE_DIR ARB4J_LIB_DIR ARB4J_CLASSPATH
