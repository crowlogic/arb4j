#!/bin/sh
# Sourced by every /usr/bin wrapper to point at the FHS-installed arb4j layout.
ARB4J_HOME=/usr/share/arb4j
ARB4J_JAR=/usr/share/java/arb4j.jar
ARB4J_NATIVE_DIR=/usr/lib/jni
# Shaded fat jar: every transitive dependency is relocated inside arb4j.jar.
ARB4J_CLASSPATH=$ARB4J_JAR
export ARB4J_HOME ARB4J_JAR ARB4J_NATIVE_DIR ARB4J_CLASSPATH
