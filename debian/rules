#!/usr/bin/make -f

export JAVA_HOME := /usr/lib/jvm/java-26-openjdk-$(shell dpkg-architecture -qDEB_HOST_ARCH)
export PATH      := $(JAVA_HOME)/bin:$(PATH)

PKG     := arb4j
DOCPKG  := arb4j-doc
VER     := $(shell bin/arb4jVersion)
DESTDIR := $(CURDIR)/debian/$(PKG)
DOCDEST := $(CURDIR)/debian/$(DOCPKG)

JAR_DIR  := $(DESTDIR)/usr/share/java
JNI_DIR  := $(DESTDIR)/usr/lib/jni
HOME_DIR := $(DESTDIR)/usr/share/$(PKG)
BIN_DIR  := $(DESTDIR)/usr/bin
DOC_DIR  := $(DOCDEST)/usr/share/doc/$(PKG)/api

%:
	dh $@ --with javahelper

override_dh_auto_clean:

override_dh_auto_build:
	$(MAKE) libarblib.so
	$(MAKE) jar
	$(MAKE) documentation

override_dh_auto_test:

override_dh_auto_install:
	install -d $(JAR_DIR) $(JNI_DIR) $(HOME_DIR) $(BIN_DIR) $(DOC_DIR)
	install -m 0644 libarblib.so                  $(JNI_DIR)/libarblib.so
	# Shaded fat jar: every transitive dependency relocated under
	# org.arblib.shaded.* (third-party libs) or kept at canonical paths
	# (javafx.*). JavaFX is not shipped by the runtime OpenJDK, so the
	# javafx classes and their linux-classifier native libs ride inside
	# arb4j.jar.
	install -m 0644 build/$(PKG)-$(VER).jar       $(JAR_DIR)/$(PKG)-$(VER).jar
	ln -sf $(PKG)-$(VER).jar                      $(JAR_DIR)/$(PKG).jar
	cp -a build/apidocs/.                         $(DOC_DIR)/
	install -m 0755 debian/env.sh.in              $(HOME_DIR)/env.sh
	install -m 0644 pom.xml                       $(HOME_DIR)/pom.xml
	install -m 0644 shell.start                   $(HOME_DIR)/shell.start
	echo $(VER)                                 > $(HOME_DIR)/version
	# Extract every .so from the shaded jar into /usr/lib/jni so the
	# JVM can resolve them via -Djava.library.path. JavaFX's native
	# libraries (libglass, libprism_es2, libjavafx_iio, libdecora_sse,
	# libglassgtk3, libjavafx_font*, libprism_sw, libprism_common) live
	# at the jar root once the linux-classifier artifacts are unpacked,
	# alongside libj2v8_linux_x86_64.so from the j2v8 dependency.
	cd $(JNI_DIR) && unzip -j -o $(CURDIR)/build/$(PKG)-$(VER).jar '*.so'
	# Stage every wrapper from bin/ into /usr/bin with paths rewritten
	# to the FHS layout. See debian/install-bin.sh.
	debian/install-bin.sh bin $(BIN_DIR)

override_dh_dwz:

override_dh_strip:
	dh_strip --no-automatic-dbgsym
