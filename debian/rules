#!/usr/bin/make -f

export JAVA_HOME := /usr/lib/jvm/java-26-openjdk-$(shell dpkg-architecture -qDEB_HOST_ARCH)
export PATH      := $(JAVA_HOME)/bin:$(PATH)

PKG     := arb4j
DOCPKG  := arb4j-doc
VER     := $(shell bin/arb4jVersion)
DESTDIR := $(CURDIR)/debian/$(PKG)
DOCDEST := $(CURDIR)/debian/$(DOCPKG)

JAR_DIR  := $(DESTDIR)/usr/share/java
JNI_DIR  := $(DESTDIR)/usr/lib/jni
HOME_DIR := $(DESTDIR)/usr/share/$(PKG)
LIB_DIR  := $(HOME_DIR)/lib
BIN_DIR  := $(DESTDIR)/usr/bin
DOC_DIR  := $(DOCDEST)/usr/share/doc/$(PKG)/api

%:
	dh $@ --with javahelper

override_dh_auto_clean:

override_dh_auto_build:
	$(MAKE) libarblib.so
	$(MAKE) debian-install
	$(MAKE) documentation

override_dh_auto_test:

override_dh_auto_install:
	install -d $(JAR_DIR) $(JNI_DIR) $(HOME_DIR) $(LIB_DIR) $(BIN_DIR) $(DOC_DIR)
	install -m 0644 libarblib.so                  $(JNI_DIR)/libarblib.so
	# Thin jar: only arb4j's own classes. Every transitive runtime
	# dependency ships as a discrete jar under /usr/share/arb4j/lib
	# and is enumerated in /usr/share/arb4j/class.path. env.sh exports
	# ARB4J_CLASSPATH = $ARB4J_JAR:<class.path-contents>.
	install -m 0644 build/$(PKG)-$(VER).jar       $(JAR_DIR)/$(PKG)-$(VER).jar
	ln -sf $(PKG)-$(VER).jar                      $(JAR_DIR)/$(PKG).jar
	# Copy every transitive runtime dep into /usr/share/arb4j/lib.
	# maven-dependency-plugin's copy-dependencies execution staged
	# them into build/dependency at prepare-package time.
	install -m 0644 build/dependency/*.jar        $(LIB_DIR)/
	# Install the Debian-prefixed class.path. The build-classpath-debian
	# execution rewrote every entry to /usr/share/arb4j/lib/<basename>.jar.
	install -m 0644 build/class.path.debian       $(HOME_DIR)/class.path
	cp -a build/apidocs/.                         $(DOC_DIR)/
	install -m 0755 debian/env.sh.in              $(HOME_DIR)/env.sh
	install -m 0644 pom.xml                       $(HOME_DIR)/pom.xml
	install -m 0644 shell.start                   $(HOME_DIR)/shell.start
	echo $(VER)                                 > $(HOME_DIR)/version
	# Extract every .so from the JavaFX linux-classifier and j2v8
	# native-binding jars into /usr/lib/jni so the JVM can resolve
	# them via -Djava.library.path. unzip exits with status 11 when
	# a jar contains no .so entries, which is fine for non-native
	# dependency jars; tolerate it.
	for jar in $(LIB_DIR)/javafx-*-linux.jar $(LIB_DIR)/j2v8_linux_*.jar; do \
	  [ -f "$$jar" ] || continue; \
	  ( cd $(JNI_DIR) && unzip -j -o "$$jar" '*.so' ) || true; \
	done
	# Stage every wrapper from bin/ into /usr/bin with paths rewritten
	# to the FHS layout. See debian/install-bin.sh.
	debian/install-bin.sh bin $(BIN_DIR)

override_dh_dwz:

override_dh_strip:
	dh_strip --no-automatic-dbgsym
